{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": true,
    "types": [
      "bun",
      "jest",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "frontend/**/*.test.ts",
    "frontend/**/*.test.tsx",
    "frontend/**/__tests__/**/*.ts",
    "frontend/**/__tests__/**/*.tsx",
    "frontend/__test_support__/**/*.ts",
    "frontend/__test_support__/**/*.tsx",
    "frontend/hacks.d.ts"
  ],
  "exclude": []
}
