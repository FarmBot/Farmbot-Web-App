<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type'>
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <meta content="black" name="theme-color">
    <meta content="black" name="apple-mobile-web-app-status-bar-style">
    <title>The FarmBot Web App</title>
    <meta name="description" content="Setup, customize, and control FarmBot from your computer, tablet, or smartphone.">
    <style>.fa {font-style:normal;display:inline-block;font-size:1rem;}.fa:before {content: "▢";}</style>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"
      integrity="sha512-SfTiTlX6kk+qitfevl/7LibUOeJWlt9rbyDn92a1DqWOw9vWG2MFoays0sgObmWazO5BQPiFucnnEAjpAB+/Sw=="
      crossorigin="anonymous">
    <style>
      .initial-loading-text { position: absolute; top: 385px;
      text-align: center; width: 100%; padding-top: 10%; color: #434343; }
    </style>
    <%= stylesheet_link_tag(*@css_assets, preload_links_header: false) %>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" href="/images/favicon.png" type="image/png">
    <% manifest_file =
         case ENV["API_HOST"]
         when "my.farm.bot"
           "/manifest.production.json"
         when "staging.farm.bot"
           "/manifest.staging.json"
         else
           "/manifest.local.json"
         end
    %>
    <link rel="manifest" href="<%= manifest_file %>">
    <script>
      /** L@@K!!! THIS IS IMPORT */
      window.globalConfig = <%= raw(@global_config) %>; // <= DONT MOVE
      /** ALWAYS LOAD THAT FIRST!!! ^ */
      window.process = { env: { NODE_ENV: <%= raw(Rails.env.inspect) %> } }
    </script>
    <%= render "addons" %>
    <%= yield :head %>
  </head>
  <body>
    <%= yield %>
    <%= javascript_include_tag *@js_assets, type: "module" %>
    <% if Rails.env.development? &&
         ENV.fetch("ASSET_LIVERELOAD", "true") == "true" %>
      <% asset_host = ENV.fetch("ASSET_HOST",
                                ENV.fetch("API_HOST", "localhost")) %>
      <% asset_port = ENV.fetch("ASSET_PORT", "3808") %>
      <script>
        (() => {
          const protocol = location.protocol === "https:" ? "wss" : "ws";
          const host = "<%= asset_host %>";
          const port = "<%= asset_port %>";
          const socket = new WebSocket(`${protocol}://${host}:${port}`);
          socket.addEventListener("message", (event) => {
            if (event.data === "reload") {
              location.reload();
            }
          });
        })();
      </script>
    <% end %>
  </body>
</html>
